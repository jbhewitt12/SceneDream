# SceneDream environment template
# Copy to .env and customize for your machine.
# Do not commit real secrets.

# Core app identity
PROJECT_NAME=SceneDream
ENVIRONMENT=local
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"

# PostgreSQL (required)
# Use POSTGRES_SERVER=db when running backend in Docker compose.
# Use POSTGRES_SERVER=localhost when running backend directly on host.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Docker compose naming/image settings
DOMAIN=localhost
STACK_NAME=scenedream
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
TAG=latest

# Observability (optional)
SENTRY_DSN=

# AI providers (optional, required by specific pipeline stages)
GEMINI_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=

# Image generation defaults (optional overrides)
DEFAULT_IMAGE_PROVIDER=openai_gpt_image
DEFAULT_IMAGE_MODEL=gpt-image-1.5
IMAGE_GENERATION_MODE=batch

# Social posting integration (optional)
FLICKR_ENABLED=False
FLICKR_API_KEY=
FLICKR_API_SECRET=
X_ENABLED=False
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_HOURS_BETWEEN_POSTS=2
FLICKR_HOURS_BETWEEN_POSTS=0.0167
