# SceneDream environment template
# Copy this file and then rename the copy to `.env`, then add your OpenAI API key. That's all you need to get started.

# == AI provider keys ==
OPENAI_API_KEY=
# eg. OPENAI_API_KEY=sk-proj-1234567890


# GEMINI_API_KEY is optional. When present, Gemini remains the preferred LLM
# provider for extraction, ranking, and prompt generation.
GEMINI_API_KEY=

# XAI_API_KEY is currently unused and can stay blank.
XAI_API_KEY=

# == Core app identity ==
# Required: backend startup depends on these.
PROJECT_NAME=SceneDream
ENVIRONMENT=local

# == Frontend URL / CORS ==
# Optional for local development if you use the default URL:
#   http://localhost:5173
# Change these only if your frontend runs on a different origin.
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://127.0.0.1,http://127.0.0.1:5173,https://localhost,https://localhost:5173,https://127.0.0.1,https://127.0.0.1:5173"

# == PostgreSQL ==
# Required: backend startup and migrations depend on these.
# Use POSTGRES_SERVER=db when running backend in Docker compose.
# Use POSTGRES_SERVER=localhost when running backend directly on host.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# == Docker / deployment naming ==
# Optional for local direct-run development.
# Keep the defaults unless you are changing Docker image names or using the
# Traefik deployment setup.
DOMAIN=localhost
STACK_NAME=scenedream
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
TAG=latest

# == Observability ==
# Optional: leave blank unless you want Sentry error reporting.
SENTRY_DSN=

# == Image generation defaults ==
# Optional: these defaults already work with OPENAI_API_KEY.
DEFAULT_IMAGE_PROVIDER=openai_gpt_image
DEFAULT_IMAGE_MODEL=gpt-image-1.5
IMAGE_GENERATION_MODE=batch

# == Social posting integration ==
# Optional: leave these blank unless you want posting buttons/background posting.
FLICKR_ENABLED=False
FLICKR_API_KEY=
FLICKR_API_SECRET=
X_ENABLED=False
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_HOURS_BETWEEN_POSTS=2
FLICKR_HOURS_BETWEEN_POSTS=0.0167
